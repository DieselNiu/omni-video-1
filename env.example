# -----------------------------------------------------------------------------
# Application BASE URL
# https://mksaas.com/docs/env#core-configuration
# For production, set to your domain, e.g. https://mksaas.com
# For development, set to http://localhost:3000 or any other port
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Database
# https://mksaas.com/docs/database
# -----------------------------------------------------------------------------
DATABASE_URL=""

# -----------------------------------------------------------------------------
# Better Auth
# https://mksaas.com/docs/auth
# Generate a random string for the secret key using `openssl rand -base64 32`
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=""

# -----------------------------------------------------------------------------
# Homepage Free Quota / Guest Identity
# -----------------------------------------------------------------------------
# Used to derive the anonymous abuseBindKey from server-observable signals.
# Must be independent from BETTER_AUTH_SECRET.
ABUSE_BIND_SECRET=""
# Used to sign the homepage guest_id cookie.
# Must be independent from BETTER_AUTH_SECRET and ABUSE_BIND_SECRET.
GUEST_ID_SIGNING_SECRET=""
# Optional: base URL for provider webhooks when public origin differs from
# NEXT_PUBLIC_BASE_URL (for example behind a tunnel or separate ingress).
WEBHOOK_BASE_URL=""
# Optional: homepage submit idempotency record TTL in seconds. Defaults to 60.
HOME_IDEMPOTENCY_TTL_SECONDS="60"

# -----------------------------------------------------------------------------
# Github OAuth
# https://mksaas.com/docs/auth#2-configure-github-oauth
# https://www.better-auth.com/docs/authentication/github
# Get Client information from https://github.com/settings/developers
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Google OAuth
# https://mksaas.com/docs/auth#3-configure-google-oauth
# https://www.better-auth.com/docs/authentication/google
# Get Client information from https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Yandex OAuth (Russian users)
# Register an app at https://oauth.yandex.com/ — request scopes:
#   login:email, login:info, login:avatar
# Set the callback URL to: <BASE_URL>/api/auth/oauth2/callback/yandex
# -----------------------------------------------------------------------------
YANDEX_CLIENT_ID=""
YANDEX_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Email / Newsletter (Resend)
# https://mksaas.com/docs/email
# https://mksaas.com/docs/newsletter
# Get API key and audience id from https://resend.com
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
RESEND_AUDIENCE_ID=""

# -----------------------------------------------------------------------------
# Storage (Cloudflare R2 or S3-compatible service of your choice)
# https://mksaas.com/docs/storage
# Cloudflare R2: https://www.cloudflare.com/developer-platform/products/r2
# -----------------------------------------------------------------------------
STORAGE_REGION="auto"
STORAGE_BUCKET_NAME=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_ENDPOINT=""
STORAGE_PUBLIC_URL=""

# -----------------------------------------------------------------------------
# Payment (Stripe)
# https://mksaas.com/docs/payment
# Get Stripe key and secret from https://dashboard.stripe.com
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# PayPal (server-side credentials for /api/paypal/* and webhook)
# Dashboard: https://developer.paypal.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
# Optional: bypass webhook signature verification in dev. NEVER set to true in prod.
# ALLOW_UNVERIFIED_PAYPAL_WEBHOOKS="false"

# -----------------------------------------------------------------------------
# NOWPayments (crypto checkout)
# Dashboard: https://account.nowpayments.io
# Webhook URL: https://<your-domain>/api/webhooks/nowpayments
# -----------------------------------------------------------------------------
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""
# Optional overrides:
# NOWPAYMENTS_API_BASE_URL="https://api.nowpayments.io/v1"
# NOWPAYMENTS_IPN_CALLBACK_URL=""
# Used to authenticate guarded MaxAPI image-generation webhook callbacks.
MAXAPI_WEBHOOK_SECRET=""
# Apimart (https://api.apimart.ai) API key. Used for the gpt-image-2 product.
APIMART_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# Channel routing overrides (highest priority; beats channel_config DB rows)
# ─────────────────────────────────────────────────────────────────────────────
# Format:  IMAGE_VENDOR__<FAMILY>_<VERSION>=<provider>
#   FAMILY / VERSION: uppercase, hyphens and dots replaced by underscores
#   <provider>: 'kie' | 'maxapi' | 'apimart' | 'google' | 'vertex'
# Omit VERSION for family-level overrides. Version override takes precedence.
#
# Examples (all commented out — uncomment to activate):
# IMAGE_VENDOR__NANO_BANANA_PRO=kie      # route nano-banana-pro to Kie
# IMAGE_VENDOR__NANO_BANANA=maxapi        # family-wide fallback for nano-banana
# IMAGE_VENDOR__GPT_IMAGE_2=maxapi        # swap gpt-image-2 to a MaxAPI upstream
# Pro plan - monthly subscription
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=""
# Pro plan - yearly subscription
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=""
# Lifetime plan - one-time payment
NEXT_PUBLIC_STRIPE_PRICE_LIFETIME=""
# Credit package - basic
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_BASIC=""
# Credit package - standard
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_STANDARD=""
# Credit package - premium
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_PREMIUM=""
# Credit package - enterprise
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_ENTERPRISE=""
# Credit package - max
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_MAX=""
# Credit package - ultra
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_ULTRA=""

# -----------------------------------------------------------------------------
# Configurations
# -----------------------------------------------------------------------------
# Disable image optimization, check out next.config.ts for more details
# -----------------------------------------------------------------------------
DISABLE_IMAGE_OPTIMIZATION=false
# -----------------------------------------------------------------------------
# Run this website as demo website, in most cases, you should set this to false
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEMO_WEBSITE=false

# -----------------------------------------------------------------------------
# Analytics
# https://mksaas.com/docs/analytics
